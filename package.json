{
  "name": "@thkdog/codex-openai-proxy",
  "version": "1.0.0",
  "description": "Use local Codex auth.json to expose an OpenAI-compatible proxy server",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "codex-openai-proxy": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "openai",
    "codex",
    "proxy",
    "openai-compatible",
    "chatgpt"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thkdog/codex-openai-proxy.git"
  },
  "homepage": "https://github.com/thkdog/codex-openai-proxy#readme",
  "bugs": {
    "url": "https://github.com/thkdog/codex-openai-proxy/issues"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  }
}
